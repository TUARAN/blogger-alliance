{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "blogger-alliance",
  "main": "cloudflare/worker.js",
  "compatibility_date": "2026-04-19",
  "assets": {
    "directory": "./dist"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "blogger-alliance",
      "database_id": "REPLACE_WITH_YOUR_D1_DATABASE_ID"
    }
  ]
}
