{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "blogger-alliance",
  "main": "cloudflare/worker.js",
  "compatibility_date": "2026-04-18",
  "workers_dev": true,
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "blogger-alliance",
      "database_id": "587fe4fc-cae3-44c9-a591-9e24670c3337"
    }
  ],
  "routes": [
    {
      "pattern": "blogger-alliance.cn",
      "custom_domain": true
    },
    {
      "pattern": "cloudcost.blogger-alliance.cn",
      "custom_domain": true
    }
  ]
}
